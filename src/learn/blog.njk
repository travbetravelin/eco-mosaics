---
layout: base.njk
title: Blog & Field Notes | Eco Mosaics Restoration
description: Practical writing on stewardship practices, species profiles, case studies, and observations from active work across the Bay Area.
---

<style>
  .post-list {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }
  .post-list-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--mist);
  }
  .post-list-item:first-child { padding-top: 0; }
  .post-list-item .label-tag {
    margin-bottom: 8px;
    font-size: 1rem;
  }
  .post-list-item h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--bark);
    margin-bottom: 10px;
    line-height: 1.25;
  }
  .post-list-item h2 a {
    color: inherit;
    text-decoration: none;
  }
  .post-list-item h2 a:hover { color: var(--water); }
  .post-list-item p {
    font-size: 1rem;
    color: #6a5a4a;
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .post-read-link {
    font-size: 1rem;
    color: var(--water);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .no-posts {
    color: #8a7a6a;
    font-size: 1rem;
    padding: 48px 0;
  }
</style>

<section class="content-section" style="padding-bottom: 0;">
  <div class="container">
    <p class="label-tag">Learn — Field Notes</p>
    <h1 class="section-title">Dispatches from the Field</h1>
    <p class="section-lead">Practical writing on stewardship, species, and observations from active work across the Bay Area. Written for landowners and curious people alike — no jargon required.</p>
  </div>
</section>

<div class="container">
  <div class="post-list">
    {% if collections.posts and collections.posts.length %}
      {% for post in collections.posts | reverse %}
      <div class="post-list-item">
        {% if post.data.category %}<p class="label-tag">{{ post.data.category }}</p>{% endif %}
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
        <a href="{{ post.url }}" class="post-read-link">Read →</a>
      </div>
      {% endfor %}
    {% else %}
      <p class="no-posts">No posts yet — check back soon.</p>
    {% endif %}
  </div>
</div>
