---
layout: base.njk
---
<style>
  .post-header {
    padding: 64px 0 40px;
    border-bottom: 1px solid var(--mist);
  }
  .post-header .label-tag { margin-bottom: 14px; }
  .post-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.15;
    color: var(--bark);
    margin-bottom: 10px;
  }
  .post-header .post-meta {
    font-size: 1rem;
    color: #8a7a6a;
    letter-spacing: 0.06em;
  }
  .post-body {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  .post-body h1, .post-body h2 {
    font-family: 'Playfair Display', serif;
    color: var(--bark);
    line-height: 1.2;
    margin-top: 2.4em;
    margin-bottom: 0.6em;
  }
  .post-body h1 { font-size: 1.8rem; }
  .post-body h2 {
    font-size: 1.4rem;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--mist);
  }
  .post-body h3 {
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--water);
    margin-top: 2em;
    margin-bottom: 0.8em;
  }
  .post-body p {
    font-size: 1rem;
    line-height: 1.85;
    color: #4a3a2a;
    margin-bottom: 1em;
  }
.post-body strong { color: var(--bark); font-weight: 600; }
  .post-body em { font-style: italic; color: #6a5a4a; }
  .post-body hr {
    border: none;
    border-top: 1px solid var(--mist);
    margin: 2em 0;
  }
  .post-body ul, .post-body ol {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }
  .post-body li {
    font-size: 1rem;
    line-height: 1.75;
    color: #4a3a2a;
    margin-bottom: 0.3em;
  }
  .post-body table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
    margin: 1.4em 0;
  }
  .post-body th {
    text-align: left;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--water);
    padding: 8px 12px;
    border-bottom: 2px solid var(--mist);
  }
  .post-body td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--mist);
    color: #4a3a2a;
    line-height: 1.5;
  }
  .post-body tr:last-child td { border-bottom: none; }
  .post-body tbody tr:hover { background: var(--pale); }
  .post-body img {
    width: 100%;
    border-radius: var(--radius);
    margin: 1.6em 0;
    border: 1px solid var(--mist);
  }
  .post-body code {
    font-family: 'DM Mono', monospace;
    font-size: 1em;
    background: var(--pale);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--moss);
  }
  @media (max-width: 600px) {
    .post-body table { display: block; overflow-x: auto; }
    .post-body th, .post-body td { padding: 6px 8px; }
  }
</style>

<div class="post-header">
  <div class="container">
    <p class="label-tag">{{ category if category else "Field Notes" }}</p>
    <h1>{{ title }}</h1>
    {% if subtitle %}<p class="post-meta">{{ subtitle }}</p>{% endif %}
    <p class="post-meta">
      {% if author %}{{ author }}{% endif %}{% if author and date %} &nbsp;·&nbsp; {% endif %}{% if date %}{{ date | date("MMMM D, YYYY") }}{% endif %}
    </p>
  </div>
</div>

<div class="container">
  <div class="post-body">
    {{ content | safe }}
  </div>
</div>
