<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Lora:ital,wght@0,600;1,400&family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="canonical" href="https://ecomosaicsrestoration.com{{ page.url }}">
  {% block head %}{% endblock %}
  <script defer src="https://umami-production-68ce.up.railway.app/script.js" data-website-id="03559110-789c-40ec-973f-51fe684cf85a"></script>
</head>
<body>

<!-- ── NAV ──────────────────────────────────────────────────── -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Eco Mosaics Restoration</a>
      <ul class="nav-links">
        <li><a href="/about">About</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/learn">Learn</a></li>
        <li class="nav-cta"><a href="/contact">Get in Touch →</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Open navigation"><span></span><span></span><span></span></button>
    </div>
  </div>
</nav>

{{ content | safe }}

<!-- ── FOOTER ────────────────────────────────────────────────── -->
<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo">Eco Mosaics Restoration</a>
        <p class="footer-tagline">Land stewardship for a more resilient, biodiverse San Francisco Bay Area.</p>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services/restoration">Habitat Restoration</a></li>
          <li><a href="/services/invasives">Invasive Species Removal</a></li>
          <li><a href="/services/coexistence">Beaver Coexistence</a></li>
          <li><a href="/services/consulting">Consulting & Assessments</a></li>
          <li><a href="/contact">Book a Site Visit</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <ul>
          <li><a href="/learn/blog">Field Notes</a></li>
          <li><a href="/learn/case-studies">Case Studies</a></li>
          <li><a href="/learn/get-involved">Get Involved</a></li>
          <li><a href="/learn/faq">FAQ</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/about/mission">Our Mission</a></li>
          <li><a href="/about/team">The Team</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Eco Mosaics Restoration LLC. All rights reserved.</span>
      <span>San Francisco Bay Area.</span>
    </div>
  </div>
</footer>

<script>
  const navToggle = document.querySelector('.nav-toggle');
  const navLinks  = document.querySelector('.nav-links');
  navToggle.addEventListener('click', () => {
    navToggle.classList.toggle('open');
    navLinks.classList.toggle('open');
  });
  navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    navToggle.classList.remove('open');
    navLinks.classList.remove('open');
  }));
</script>
</body>
</html>
